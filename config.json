
{
  "inspectionMeta": {
    "inspectionName": "Dispensary Visit Scorecard",
    "version": "1.1.0",
    "baseScoreMax": 100,
    "bonusScoreMax": 10,
    "pointsPerQuestion": 2,
    "scoringModel": "yes_no",
    "finalScoreFormula": "baseScore + bonusScore"
  },

  "header": {
    "fields": [
      { "id": "storeLocation", "label": "Store Location", "type": "text", "required": true },
      { "id": "storeManagers", "label": "Store Manager(s)", "type": "text", "required": true },
      { "id": "visitDate", "label": "Date of Visit", "type": "date", "required": true },
      { "id": "inspector", "label": "Person Visiting", "type": "text", "required": true }
    ]
  },

  "sections": [
 {
  "title": "Exterior Appearance",
  "questions": [
    {
      "id": "ext_parking_clean",
      "label": "Parking lot is free of trash and debris"
    },
    {
      "id": "ext_lighting_signage_functional",
      "label": "Exterior lights and store signage are functioning properly"
    },
    {
      "id": "ext_landscaping_maintained",
      "label": "Landscaping is clean, orderly, and well maintained"
    },
    {
      "id": "ext_building_condition",
      "label": "Building exterior is clean and in good condition"
    },
    {
      "id": "ext_required_signage_visible",
      "label": "Required signage is posted and clearly visible (DCC, weapons, hours of operation)"
    },
    {
      "id": "ext_doors_functional",
      "label": "Entry doors are clean and in proper working condition"
    },
    {
      "id": "ext_trash_area_secured",
      "label": "Trash and waste areas are secured and locked"
    }
  ]
},
    {
      "id": "customerExperience",
      "title": "Customer Experience",
      "questions": [
        { "id": "guestsGreeted", "label": "Guests Being Greeted?" },
        { "id": "kiosksProper", "label": "Kiosks Being Used Properly?" },
        { "id": "hospitalityVsService", "label": "Hospitality vs Service?" },
        { "id": "knowsPromos", "label": "Team Members Know Promos?" },
        { "id": "smiling", "label": "Smiling?" }
      ]
    },
    {
      "id": "inventory",
      "title": "Inventory",
      "questions": [
        {
          "id": "inventoryDiscrepancies",
          "label": "No discrepancies observed?"
        },
        {
          "id": "inventoryOrganized",
          "label": "Visually Organized?"
        },
        {
          "id": "inventoryCompliant",
          "label": "Visually Compliant?"
        },
        {
          "id": "quarantineBin",
          "label": "Quarantine Bin Accurate and to Standard?"
        }
      ]
    },
    {
      "id": "merchandising",
      "title": "Merchandising & Visual Standards",
      "questions": [
        {
          "id": "budbarStandard",
          "label": "Budbar Out & Up to Standard?"
        },
        {
          "id": "tvsCompliant",
          "label": "TV’s On and Compliant?"
        },
        {
          "id": "marketingCurrent",
          "label": "Marketing Product Current and Orderly?"
        },
        {
          "id": "promoVisuals",
          "label": "Promo Visuals / Flyers in Place?"
        }
      ]
    }
  ],

  "bonusSection": {
    "id": "positiveExperiences",
    "title": "Positive Experiences Observed",
    "description": "Optional bonus points for observed excellence. Notes required.",
    "maxBonusPoints": 10,
    "pointsPerEntry": 2,
    "fields": [
      { "id": "teamMember", "label": "Team Member Name", "type": "text", "required": true }
    ]
  },

  "logic": {
    "scorePerYes": 2,
    "scorePerNo": 0,
    "notesRequiredIfNo": true,
    "bonusCalculation": "min(entries * pointsPerEntry, maxBonusPoints)"
  }
}
