
{
  "inspectionMeta": {
    "inspectionName": "Dispensary Visit Scorecard",
    "version": "1.1.0",
    "baseScoreMax": 100,
    "bonusScoreMax": 10,
    "pointsPerQuestion": 2,
    "scoringModel": "yes_no",
    "finalScoreFormula": "baseScore + bonusScore"
  },

  "header": {
    "fields": [
      { "id": "storeLocation", "label": "Store Location", "type": "text", "required": true },
      { "id": "storeManagers", "label": "Store Manager(s)", "type": "text", "required": true },
      { "id": "visitDate", "label": "Date of Visit", "type": "date", "required": true },
      { "id": "inspector", "label": "Person Visiting", "type": "text", "required": true }
    ]
  },

  "sections": [
    {
      "id": "firstImpressions",
      "title": "First Impressions",
      "questions": [
        { "id": "exteriorCleanliness", "label": "Exterior Cleanliness?" },
        { "id": "signageVisibility", "label": "Signage and Visibility?" },
        { "id": "entryExperience", "label": "Fast and Friendly Entry Experience?" },
        { "id": "securityProfessionalism", "label": "Security Professionalism?" },
        { "id": "musicAppropriate", "label": "Music On and Appropriate?" }
      ]
    },
    {
      "id": "compliance",
      "title": "Compliance",
      "questions": [
        { "id": "guestCheckIn", "label": "Guest Check-in Process Up to Standard?" },
        { "id": "cameraCompliance", "label": "Cameras / Security Compliant?" },
        { "id": "cashHandlingCompliance", "label": "Cash Handling Compliant?" },
        { "id": "logsReports", "label": "Logs / Reports Up to Date?" }
      ]
    },
    {
      "id": "customerExperience",
      "title": "Customer Experience",
      "questions": [
        { "id": "guestsGreeted", "label": "Guests Being Greeted?" },
        { "id": "kiosksProper", "label": "Kiosks Being Used Properly?" },
        { "id": "hospitalityVsService", "label": "Hospitality vs Service?" },
        { "id": "knowsPromos", "label": "Team Members Know Promos?" },
        { "id": "smiling", "label": "Smiling?" }
      ]
    },
    {
      "id": "inventory",
      "title": "Inventory",
      "questions": [
        { "id": "inventoryDiscrepancies", "label": "Discrepancies?" },
        { "id": "inventoryOrganized", "label": "Visually Organized?" },
        { "id": "inventoryCompliant", "label": "Visually Compliant?" },
        { "id": "quarantineBin", "label": "Quarantine Bin Accurate and to Standard?" }
      ]
    },
    {
      "id": "merchandising",
      "title": "Merchandising & Visual Standards",
      "questions": [
        { "id": "budbarStandard", "label": "Budbar Out & Up to Standard?" }
]
    }
  ],

  "bonusSection": {
    "id": "positiveExperiences",
    "title": "Positive Experiences Observed",
    "description": "Optional bonus points for observed excellence. Notes required.",
    "maxBonusPoints": 10,
    "pointsPerEntry": 2,
    "fields": [
      { "id": "teamMember", "label": "Team Member Name", "type": "text", "required": true }
    ]
  },

  "logic": {
    "scorePerYes": 2,
    "scorePerNo": 0,
    "notesRequiredIfNo": true,
    "bonusCalculation": "min(entries * pointsPerEntry, maxBonusPoints)"
  }
}
